# ==============================================================================
# 2U.TV AGENTIC OS - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# Anthropic Claude API Key (Intelligence Layer CEO)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Integration API Host Pointers (Workers & Router)
# Configure these to match your Hostinger VPS deployment addresses
OPENCLAW_URL=http://your-openclaw-ip-or-domain:8000
HERMES_1_URL=http://your-hermes-1-ip-or-domain:8001
HERMES_2_URL=http://your-hermes-2-ip-or-domain:8002

# Memory Layer: Local Working Directory of the Git-Synced Obsidian Vault
# Production Hostinger path: /var/agentos/vault
# Local Windows path fallback: ./vault
OBSIDIAN_VAULT_PATH=./vault

# Dashboard Security Passcode
# Set a custom passphrase to secure the Next.js panel from public inspection
DASHBOARD_PASSCODE=agenticos-secret-access-token
